---
interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = "Architecture Red Flags", 
  subtitle = "& The Modern Backend Blueprint" 
} = Astro.props;
---

<section class="my-16 p-8 rounded-2xl bg-bg-surface border border-border-subtle relative overflow-hidden group">
  <!-- Decorative background elements matching the brand -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-accent/5 rounded-full blur-3xl -mr-32 -mt-32"></div>
  <div class="absolute bottom-0 left-0 w-48 h-48 bg-accent/5 rounded-full blur-3xl -ml-24 -mb-24"></div>
  
  <div class="grid md:grid-columns-2 lg:grid-cols-2 gap-12 items-center relative z-10">
    <!-- Left: Visual Mockup -->
    <div class="flex justify-center">
      <div class="relative w-full max-w-[280px] aspect-[1/1.41] bg-bg-deep rounded-lg shadow-2xl border border-border-subtle overflow-hidden rotate-[-2deg] group-hover:rotate-0 transition-transform duration-500">
        <!-- Minimal Mockup SVG/CSS -->
        <div class="absolute inset-0 p-6 flex flex-col justify-between bg-[#0a0f1a]">
          <div class="text-[8px] font-mono text-accent tracking-widest opacity-50">>_ INGENIERÍA SIN FILTROS</div>
          <div>
            <div class="text-2xl font-bold leading-none mb-1 text-white">ARCHITECTURE</div>
            <div class="text-3xl font-extrabold leading-none text-accent">RED FLAGS</div>
            <div class="text-[10px] text-slate-400 mt-2 font-mono italic">& The Modern Backend Blueprint</div>
          </div>
          <div class="mt-auto pt-4 border-t border-white/10 text-[6px] font-mono text-slate-500 flex justify-between">
            <span>VERSIÓN 2026</span>
            <span>ALAFOURCA.DEV</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Content & Form -->
    <div class="space-y-6">
      <div class="space-y-2">
        <span class="inline-block px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-mono tracking-wider uppercase">Lead Magnet Gratuito</span>
        <h2 class="text-3xl md:text-4xl font-bold text-txt-primary">
          {title} <span class="text-accent">{subtitle}</span>
        </h2>
        <p class="text-txt-secondary text-lg">
          La guía definitiva para detectar fallos de diseño y el mapa de referencia para construir sistemas resilientes.
        </p>
      </div>

      <div class="bg-bg-deep/50 p-6 rounded-xl border border-border-subtle">
        <p class="text-sm font-medium mb-4 text-txt-primary">Recibí el War Manual en tu inbox:</p>
        
        <form 
          action="https://buttondown.email/api/emails/embed-subscribe/alafourcadedespaigne" 
          method="post" 
          target="popupwindow" 
          class="flex flex-col sm:flex-row gap-3"
        >
          <input 
            type="email" 
            name="email" 
            id="bd-email" 
            placeholder="tu@email.com" 
            required 
            class="flex-1 px-4 py-3 rounded-lg bg-bg-surface border border-border-subtle focus:ring-2 focus:ring-accent focus:border-accent outline-none text-txt-primary transition-all"
          />
          <input type="hidden" value="1" name="embed" />
          <button 
            type="submit" 
            class="px-6 py-3 rounded-lg bg-accent text-bg-deep font-bold hover:brightness-110 active:scale-95 transition-all whitespace-nowrap"
          >
            Descargar Guía
          </button>
        </form>
        <p class="text-[10px] text-txt-muted mt-3 italic text-center sm:text-left">
          Prometido: nada de spam, solo ingeniería cruda cada 15 días.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  /* Custom shadow for the book effect */
  .shadow-2xl {
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }
</style>
