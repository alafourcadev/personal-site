---

<!-- Header -->
<section class="section-animate px-6 lg:px-[120px] pt-12 pb-6 lg:pt-16 lg:pb-8">
  <div class="max-w-3xl">
    <h1
      class="font-heading text-3xl md:text-4xl lg:text-5xl font-extrabold text-txt-primary leading-tight tracking-tight mb-4"
    >
      Mi Setup
    </h1>
    <p class="text-lg text-txt-secondary leading-relaxed">
      Hardware, software y herramientas que uso todos los días para diseñar, construir y escalar
      sistemas. Inspirado en <a
        href="https://uses.tech/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:underline">uses.tech</a
      >.
    </p>
  </div>
</section>

<!-- Sections -->
{sections.map((section, sectionIndex) => (
  <section class="section-animate px-6 lg:px-[120px] py-8 lg:py-10" style={`animation-delay: ${sectionIndex * 100}ms`}>
    <h2
      class="font-heading text-2xl lg:text-3xl font-bold text-txt-primary tracking-[-0.8px] flex items-center gap-3 mb-8"
    >
      <span class="text-accent">{section.emoji}</span>
      {section.title}
    </h2>
    <div class="flex flex-col gap-5 max-w-3xl">
      {section.items.map((item, i) => (
        <div
          class="uses-item group bg-bg-surface border border-border-subtle rounded-xl p-6 hover:border-accent/30 transition-all duration-300"
          style={`animation-delay: ${(sectionIndex * 100) + (i * 60)}ms`}
        >
          {item.href ? (
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-lg font-bold text-txt-primary group-hover:text-accent transition-colors duration-300 inline-flex items-center gap-2"
            >
              {item.name}
              <svg
                class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                />
              </svg>
            </a>
          ) : (
            <span class="text-lg font-bold text-txt-primary">{item.name}</span>
          )}
          <p class="text-txt-secondary leading-[1.7] mt-2 text-[15px]">
            {item.description}
          </p>
        </div>
      ))}
    </div>
  </section>
))}

<style>
  .section-animate {
    opacity: 0;
    transform: translateY(30px);
    animation: sectionFadeIn 0.8s ease-out forwards;
  }

  @keyframes sectionFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .uses-item {
    opacity: 0;
    animation: fadeScale 0.4s ease-out forwards;
  }

  @keyframes fadeScale {
    from {
      opacity: 0;
      transform: scale(0.97);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>
