---
interface Props {
  slug: string
  title: string
  description: string
  tags: string[]
  date: string
  readTime: string
  image: string
}

const { slug, title, description, tags, date, readTime, image } = Astro.props
---

<a
  href={`/blog/${slug}`}
  class="group flex flex-col bg-[#1e293b] rounded-xl border border-[#334155] overflow-hidden hover:border-accent/50 hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(0,0,0,0.3)] transition-all duration-300"
  data-blog-card
  data-tags={tags.join(',')}
  data-title={title.toLowerCase()}
  data-description={description.toLowerCase()}
>
  <div class="h-[180px] overflow-hidden relative">
    <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-t from-[#1e293b] to-transparent opacity-0 group-hover:opacity-60 transition-opacity duration-300" />
  </div>
  <div class="p-5 flex flex-col gap-3 flex-1">
    <div class="flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="text-[11px] font-medium text-tag-text bg-tag-bg rounded-md px-2.5 py-1 transition-all duration-300 group-hover:bg-accent/20">{tag}</span>
      ))}
    </div>
    <h3 class="text-base font-bold text-slate-100 leading-[1.4] group-hover:text-accent transition-colors duration-300">{title}</h3>
    <p class="text-[13px] text-slate-400 leading-[1.6] line-clamp-2">{description}</p>
    <div class="flex items-center gap-2 text-xs text-slate-500 mt-auto pt-2">
      <span>{date}</span>
      <span class="w-1 h-1 rounded-full bg-slate-500" />
      <span>{readTime}</span>
    </div>
  </div>
</a>

