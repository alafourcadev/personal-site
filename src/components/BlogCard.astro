---
interface Props {
  slug: string
  title: string
  description: string
  tags: string[]
  date: string
  readTime: string
  image: string
}

const { slug, title, description, tags, date, readTime, image } = Astro.props
---

<a
  href={`/blog/${slug}`}
  class="group flex flex-col bg-bg-surface rounded-xl border border-border-subtle overflow-hidden hover:border-accent/30 hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(0,0,0,0.3)] transition-all duration-300"
  data-blog-card
  data-tags={tags.join(',')}
  data-title={title.toLowerCase()}
  data-description={description.toLowerCase()}
>
  <div class="h-[180px] overflow-hidden relative">
    <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" loading="lazy" width="800" height="400" />
    <div class="absolute inset-0 bg-gradient-to-t from-bg-surface to-transparent opacity-0 group-hover:opacity-60 transition-opacity duration-300" />
  </div>
  <div class="p-5 flex flex-col gap-3 flex-1">
    <div class="flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="text-[11px] font-medium text-tag-text bg-tag-bg rounded-md px-2.5 py-1 transition-all duration-300 group-hover:bg-accent/20">{tag}</span>
      ))}
    </div>
    <h3 class="text-base font-bold text-txt-primary leading-[1.4] group-hover:text-accent transition-colors duration-300">{title}</h3>
    <p class="text-[13px] text-txt-secondary leading-[1.6] line-clamp-2">{description}</p>
    <div class="flex items-center gap-2 text-xs text-txt-muted mt-auto pt-2">
      <time datetime={date}>{date}</time>
      <span class="w-1 h-1 rounded-full bg-txt-muted" />
      <span>{readTime}</span>
    </div>
  </div>
</a>

