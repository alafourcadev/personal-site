---
import Icon from "./Icon.astro";
---

<footer class="bg-[#1e293b]">
  <div class="px-6 lg:px-20 py-10 flex flex-col gap-6">
    <div class="h-px bg-[#334155]"></div>
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-2">
        <span class="font-mono text-lg font-bold text-accent">&gt;_</span>
        <span class="font-mono text-[15px] font-semibold text-slate-100"
          >alafourca.dev</span
        >
      </a>
      <p class="text-[13px] text-slate-500">
        &copy; {new Date().getFullYear()} Alejandro Lafourcade. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-4">
        <a
          href="https://github.com/alafourcadev"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-500 hover:text-slate-300 transition-colors"
          aria-label="GitHub"
        >
          <Icon name="github" size={18} />
        </a>
        <a
          href="https://www.linkedin.com/in/alafourcadedespaigne/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-500 hover:text-slate-300 transition-colors"
          aria-label="LinkedIn"
        >
          <Icon name="linkedin" size={18} />
        </a>
        <a
          href="https://x.com/alafourcadev"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-500 hover:text-slate-300 transition-colors"
          aria-label="Twitter"
        >
          <Icon name="twitter" size={18} />
        </a>
      </div>
    </div>
  </div>
</footer>
