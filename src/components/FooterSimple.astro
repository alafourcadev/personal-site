---
import Icon from "./Icon.astro";
---

<footer class="bg-bg-surface">
  <div class="px-4 sm:px-6 md:px-10 lg:px-20 py-8 sm:py-10 flex flex-col gap-6">
    <!-- Newsletter -->
    <form
      action="https://buttondown.com/api/emails/embed-subscribe/alafourcadedespaigne"
      method="post"
      class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto w-full"
    >
      <input
        type="email"
        name="email"
        placeholder="Suscribite al newsletter — tu@email.com"
        required
        class="flex-1 px-4 py-3 min-h-[44px] rounded-xl bg-bg-deep border border-border-subtle text-txt-primary placeholder:text-txt-muted text-sm focus:outline-none focus:border-accent/50 transition-colors"
      />
      <button
        type="submit"
        class="px-5 py-3 min-h-[44px] bg-accent text-bg-deep font-bold rounded-xl hover:shadow-[0_8px_30px_rgba(52,211,153,0.3)] transition-all duration-300 text-sm whitespace-nowrap"
      >
        Suscribirme
      </button>
    </form>
    <div class="h-px bg-border-subtle"></div>
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-2 min-h-[44px]">
        <span class="font-mono text-lg font-bold text-accent">&gt;_</span>
        <span class="font-mono text-[15px] font-semibold text-txt-primary"
          >Ingeniería sin filtros</span
        >
      </a>
      <p class="text-[13px] text-txt-muted text-center">
        &copy; {new Date().getFullYear()} Alejandro Lafourcade. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-1">
        <a
          href="https://github.com/alafourcadev"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-11 h-11 rounded-lg text-txt-muted hover:text-txt-secondary transition-colors"
          aria-label="GitHub"
        >
          <Icon name="github" size={20} />
        </a>
        <a
          href="https://www.linkedin.com/in/alafourcadedespaigne/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-11 h-11 rounded-lg text-txt-muted hover:text-txt-secondary transition-colors"
          aria-label="LinkedIn"
        >
          <Icon name="linkedin" size={20} />
        </a>
        <a
          href="https://x.com/alafourcadev"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-11 h-11 rounded-lg text-txt-muted hover:text-txt-secondary transition-colors"
          aria-label="Twitter"
        >
          <Icon name="twitter" size={20} />
        </a>
      </div>
    </div>
  </div>
</footer>
