---
// Fixed typewriter logo in top-left corner with infinite loop
---

<a href="/" class="fixed top-4 left-6 z-50 flex items-center gap-1.5 group">
    <span class="font-mono text-xl font-bold text-accent"> &gt;_ </span>
    <span
        class="logo-text font-mono text-base font-semibold text-txt-primary overflow-hidden whitespace-nowrap transition-colors duration-300"
    >
        Ingeniería sin filtros
    </span>
</a>

<style>
    .logo-text {
        width: 0;
        border-right: 2px solid transparent;
        animation:
            typewriter 2.5s steps(23) forwards,
            blink-caret 0.6s step-end infinite,
            delete-text 1.2s steps(23) forwards 6s,
            typewriter 2.5s steps(23) forwards 7.5s !important;
        animation-iteration-count: 1, infinite, 1, 1 !important;
        animation-duration: 2.5s, 0.6s, 1.2s, 2.5s !important;
    }

    @keyframes typewriter {
        0% {
            width: 0;
        }
        100% {
            width: 100%;
        }
    }

    @keyframes delete-text {
        0% {
            width: 100%;
        }
        100% {
            width: 0;
        }
    }

    @keyframes blink-caret {
        0%,
        100% {
            border-right-color: transparent;
        }
        50% {
            border-right-color: #34d399;
        }
    }
</style>

<script>
    // Restart the typewriter animation every 10 seconds (matches full cycle)
    const logoText = document.querySelector(".logo-text") as HTMLElement;

    function restartAnimation() {
        if (logoText) {
            logoText.style.animation = "none";
            logoText.offsetHeight; // Trigger reflow
            logoText.style.animation = "";
        }
    }

    setInterval(restartAnimation, 10000);
</script>
