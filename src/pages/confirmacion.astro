---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout 
  title="¡Casi listo! — Ingeniería sin filtros" 
  description="Confirmá tu suscripción para recibir el Blueprint de Arquitectura."
  navVariant="blog"
  footerVariant="simple"
>
  <section class="min-h-[70vh] flex flex-col items-center justify-center px-4 py-20 relative overflow-hidden">
    <!-- Brand elements -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-accent/5 rounded-full blur-[120px] -mr-48 -mt-48"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-accent/5 rounded-full blur-[120px] -ml-48 -mb-48"></div>

    <div class="max-w-2xl w-full text-center relative z-10 space-y-8">
      <div class="flex justify-center">
        <div class="w-20 h-20 rounded-2xl bg-accent/10 border border-accent/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
      </div>

      <div class="space-y-4">
        <h1 class="text-4xl md:text-5xl font-extrabold text-txt-primary tracking-tight">
          ¡Casi listo! Solo falta un <span class="text-accent">último paso.</span>
        </h1>
        <p class="text-xl text-txt-secondary leading-relaxed">
          Te enviamos un email para confirmar tu suscripción. <br class="hidden md:block" />
          <strong class="text-txt-primary">Revisá tu inbox (y la carpeta de spam o promociones)</strong> para activar tu acceso al Blueprint.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center pt-8">
        <a 
          href="/blog" 
          class="px-8 py-4 rounded-xl bg-accent text-bg-deep font-bold hover:shadow-[0_8px_30px_rgba(52,211,153,0.3)] hover:-translate-y-1 transition-all"
        >
          Volver al Blog
        </a>
      </div>

      <p class="text-sm text-txt-muted font-mono tracking-tighter">
        >_ INGENIERÍA SIN FILTROS · ALAFOURCA.DEV
      </p>
    </div>
  </section>
</BaseLayout>
