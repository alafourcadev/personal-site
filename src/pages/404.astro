---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Página no encontrada"
  navVariant="blog"
  footerVariant="simple"
>
  <section class="flex flex-col items-center justify-center text-center min-h-[60vh] px-6">
    <h1 class="text-6xl sm:text-8xl font-extrabold text-accent mb-4">404</h1>
    <p class="text-lg sm:text-xl text-txt-secondary mb-8 px-4">
      Esta página no existe o fue movida.
    </p>
    <a
      href="/"
      class="bg-accent text-bg-deep rounded-xl px-6 py-3 min-h-[44px] inline-flex items-center font-bold hover:opacity-90 transition-opacity"
    >
      Volver al inicio
    </a>
  </section>
</BaseLayout>
