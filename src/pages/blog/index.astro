---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

// Generate filter tags dynamically from all posts
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))];
const filterTags = ["All", ...allTags];

// Format date helper
function formatDate(date: Date): string {
  return date.toLocaleDateString("es-ES", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<BaseLayout
  title="Blog — Ingeniería sin filtros"
  description="Artículos sobre ingeniería de software, arquitectura de sistemas y las decisiones técnicas que nadie te enseña."
  navVariant="blog"
  footerVariant="simple"
>
  <!-- Blog Header -->
  <section class="flex flex-col items-center gap-8 px-6 lg:px-20 py-[60px]">
    <span class="font-mono text-sm font-medium text-accent animate-pulse"
      >// blog</span
    >
    <h1
      class="text-3xl lg:text-[42px] font-bold text-slate-100 text-center animate-fade-in"
    >
      Artículos
    </h1>
    <p
      class="text-[17px] text-slate-400 text-center max-w-2xl animate-fade-in"
      style="animation-delay: 100ms"
    >
      Ingeniería de software, arquitectura de sistemas y las decisiones técnicas
      que nadie te enseña.
    </p>

    <!-- Search -->
    <div
      class="search-container flex items-center gap-3 w-full max-w-[560px] h-12 bg-[#1e293b] border border-[#334155] rounded-xl px-4 transition-all duration-300 focus-within:border-accent/50 focus-within:shadow-[0_0_20px_rgba(52,211,153,0.15)]"
    >
      <Icon
        name="search"
        size={18}
        class="text-slate-500 shrink-0 transition-colors duration-300"
      />
      <input
        id="blog-search"
        type="text"
        placeholder="Buscar artículos..."
        class="bg-transparent text-[15px] text-slate-100 placeholder:text-slate-500 outline-none flex-1"
      />
    </div>

    <!-- Tags -->
    <div class="flex flex-wrap items-center gap-2.5 justify-center">
      {
        filterTags.map((tag, i) => (
          <button
            data-tag={tag}
            class:list={[
              "tag-btn text-[13px] font-medium rounded-full px-[18px] py-2 transition-all duration-300 cursor-pointer hover:scale-105",
              i === 0
                ? "bg-accent text-[#0f172a] font-semibold active-tag shadow-[0_0_15px_rgba(52,211,153,0.3)]"
                : "bg-[#1e293b] text-slate-400 border border-[#334155] hover:border-accent/50 hover:text-slate-200",
            ]}
            style={`animation-delay: ${i * 50}ms`}
          >
            {tag}
          </button>
        ))
      }
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="px-6 lg:px-20 pb-20">
    <div
      id="blog-grid"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
    >
      {
        posts.map((post, i) => (
          <div
            class="blog-card-wrapper"
            style={`animation-delay: ${i * 100}ms`}
          >
            <BlogCard
              slug={post.slug}
              title={post.data.title}
              description={post.data.description}
              tags={post.data.tags}
              date={formatDate(post.data.date)}
              readTime={post.data.readTime}
              image={post.data.image}
            />
          </div>
        ))
      }
    </div>
    <p id="no-results" class="hidden text-center text-slate-500 py-12">
      No se encontraron artículos.
    </p>
  </section>
</BaseLayout>

<script>
  const searchInput = document.getElementById(
    "blog-search",
  ) as HTMLInputElement | null;
  const tagButtons = document.querySelectorAll<HTMLButtonElement>(".tag-btn");
  const cards = document.querySelectorAll<HTMLElement>("[data-blog-card]");
  const noResults = document.getElementById("no-results");

  let activeTag = "All";

  function filterCards() {
    const query = searchInput?.value.toLowerCase() ?? "";
    let visible = 0;

    cards.forEach((card) => {
      const tags = card.dataset.tags ?? "";
      const title = card.dataset.title ?? "";
      const description = card.dataset.description ?? "";

      const matchesTag = activeTag === "All" || tags.includes(activeTag);
      const matchesSearch =
        query === "" || title.includes(query) || description.includes(query);

      const show = matchesTag && matchesSearch;
      card.style.display = show ? "" : "none";
      if (show) visible++;
    });

    if (noResults) noResults.style.display = visible === 0 ? "block" : "none";
  }

  searchInput?.addEventListener("input", filterCards);

  tagButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeTag = btn.dataset.tag ?? "All";

      tagButtons.forEach((b) => {
        if (b.dataset.tag === activeTag) {
          b.className =
            "tag-btn text-[13px] font-semibold rounded-full px-[18px] py-2 transition-all duration-300 cursor-pointer hover:scale-105 bg-accent text-[#0f172a] active-tag shadow-[0_0_15px_rgba(52,211,153,0.3)]";
        } else {
          b.className =
            "tag-btn text-[13px] font-medium rounded-full px-[18px] py-2 transition-all duration-300 cursor-pointer hover:scale-105 bg-[#1e293b] text-slate-400 border border-[#334155] hover:border-accent/50 hover:text-slate-200";
        }
      });

      filterCards();
    });
  });
</script>

<style>
  /* Fade in animation */
  .animate-fade-in {
    opacity: 0;
    animation: fadeIn 0.6s ease-out forwards;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }

  /* Blog card staggered animation */
  .blog-card-wrapper {
    opacity: 0;
    animation: cardSlideIn 0.5s ease-out forwards;
  }

  @keyframes cardSlideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Tag buttons animation */
  .tag-btn {
    opacity: 0;
    animation: tagFadeIn 0.3s ease-out forwards;
  }

  @keyframes tagFadeIn {
    to {
      opacity: 1;
    }
  }
</style>
