---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import BlogCard from "../../components/BlogCard.astro";
import Comments from "../../components/Comments.astro";
import LeadMagnet from "../../components/LeadMagnet.astro";
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content, headings } = await post.render();

// Auto-calculate read time from word count
const wordCount = post.body.split(/\s+/).length;
const readTime = Math.max(1, Math.ceil(wordCount / 200));
const readTimeText = `${readTime} min read`;

// Get related posts (prioritize shared tags, then by date)
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const currentTags = post.data.tags;
const otherPosts = allPosts.filter((p) => p.slug !== post.slug);

// Score posts by shared tags
const scored = otherPosts.map((p) => ({
  post: p,
  score: p.data.tags.filter((tag: string) => currentTags.includes(tag)).length,
}));

// Sort by score (most shared tags first), then by date
const relatedPosts = scored
  .sort((a, b) => b.score - a.score || b.post.data.date.getTime() - a.post.data.date.getTime())
  .slice(0, 3)
  .map((s) => s.post);

// Format date helper
function formatDate(date: Date): string {
  return date.toLocaleDateString("es-ES", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

// Build TOC from headings
const tocItems = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ label: h.text, id: h.slug }));
---

<BaseLayout
  title={`${post.data.title} — Ingeniería sin filtros`}
  description={post.data.description}
  image={'https://alafourca.dev' + post.data.image}
  type="article"
  navVariant="blog"
  footerVariant="simple"
>
  <!-- JSON-LD BlogPosting -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "image": "https://alafourca.dev" + post.data.image,
    "datePublished": post.data.date.toISOString(),
    "author": {
      "@type": "Person",
      "name": "Alejandro Lafourcade",
      "url": "https://alafourca.dev"
    },
    "publisher": {
      "@type": "Person",
      "name": "Alejandro Lafourcade",
      "url": "https://alafourca.dev"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://alafourca.dev/blog/${post.slug}`
    }
  })} />

  <!-- JSON-LD BreadcrumbList -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Inicio",
        "item": "https://alafourca.dev"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog",
        "item": "https://alafourca.dev/blog"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": post.data.title,
        "item": `https://alafourca.dev/blog/${post.slug}`
      }
    ]
  })} />

  <!-- Article Header -->
  <section
    class="flex flex-col items-center gap-4 sm:gap-6 px-4 sm:px-6 md:px-16 lg:px-[200px] py-8 sm:py-12 md:py-[60px]"
  >
    <div class="flex items-center gap-2">
      <a href="/blog" class="text-sm text-accent hover:underline">Blog</a>
      <Icon name="chevron-right" size={14} class="text-txt-muted" />
      <span class="text-sm text-txt-muted">{post.data.tags[0]}</span>
    </div>
    {post.data.day && (
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent/30 bg-accent/5">
        <span class="text-accent text-sm font-bold">DÍA {post.data.day}</span>
        <span class="text-txt-muted text-sm">·</span>
        <span class="text-txt-secondary text-sm font-medium">#100ArchitectureDays</span>
      </div>
    )}
    <div class="flex flex-wrap items-center gap-2">
      {
        post.data.tags.map((tag: string) => (
          <span class="text-xs font-medium text-tag-text bg-tag-bg rounded px-3 py-1">
            {tag}
          </span>
        ))
      }
    </div>
    <h1
      class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-extrabold text-txt-primary text-center leading-tight tracking-[-0.5px] max-w-[900px]"
    >
      {post.data.title}
    </h1>
    <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-5 text-sm">
      <div class="flex items-center gap-2.5">
        <img src="/profile.jpg" alt="Alejandro Lafourcade" class="w-8 h-8 rounded-full object-cover" />
        <span class="text-txt-primary font-medium text-xs sm:text-sm">Alejandro Lafourcade</span>
      </div>
      <span class="w-1 h-1 rounded-full bg-txt-muted hidden sm:block"></span>
      <span class="text-txt-secondary text-xs sm:text-sm">{formatDate(post.data.date)}</span>
      <span class="w-1 h-1 rounded-full bg-txt-muted"></span>
      <span class="text-txt-secondary text-xs sm:text-sm">{readTimeText}</span>
    </div>
  </section>

  <!-- Cover Image -->
  <section class="px-4 sm:px-6 md:px-10 lg:px-20">
    <div
      class="w-full rounded-xl overflow-hidden"
    >
      <img
        src={post.data.image}
        alt={post.data.title}
        class="w-full h-auto max-h-[350px] object-contain"
        loading="eager"
        width="1200"
        height="630"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- Content Area -->
  <section class="flex gap-8 md:gap-10 lg:gap-12 px-4 sm:px-6 md:px-10 lg:px-20 py-8 sm:py-12">
    <!-- TOC Sidebar -->
    {
      tocItems.length > 0 && (
        <aside class="hidden lg:flex flex-col gap-4 w-[260px] shrink-0 sticky top-24 self-start">
          <h3 class="font-mono text-[11px] font-bold text-txt-muted tracking-[1px] uppercase">
            Contenido
          </h3>
          <div class="h-px bg-border-subtle" />
          <nav class="flex flex-col">
            {tocItems.map((item, i) => (
              <a
                href={`#${item.id}`}
                id={`toc-heading-${i}`}
                data-toc-link={item.id}
                class="text-sm py-2.5 pl-3 border-l-2 transition-colors border-transparent text-txt-muted hover:text-txt-secondary hover:border-border-subtle"
              >
                {item.label}
              </a>
            ))}
          </nav>
        </aside>
      )
    }

    <!-- Article -->
    <article class="flex-1 min-w-0 prose-custom">
      <Content />

      <!-- Lead Magnet Section -->
      <div id="lead-magnet-form">
        <LeadMagnet />
      </div>

      <div class="mt-10 pt-8 border-t border-border-subtle">
        <div class="flex items-center gap-3">
          <p class="text-sm text-txt-muted">
            ¿Necesitás ayuda con tu proyecto?
            <a
              href="https://cal.com/alafourcadev/consultoria-tecnica-1-1"
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:underline font-medium"
            >
              Agendá una sesión 1:1 &rarr;
            </a>
          </p>
        </div>
      </div>

      <!-- Article Footer -->
      <div class="h-px bg-border-subtle mt-10"></div>
      <div class="flex flex-col gap-6 mt-6">
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-sm font-semibold text-txt-primary">Tags:</span>
          {
            post.data.tags.map((tag: string) => (
              <span class="text-xs font-medium text-tag-text bg-tag-bg rounded-md px-3 py-[5px]">
                {tag}
              </span>
            ))
          }
        </div>
        <div class="flex flex-wrap items-center gap-3">
          <span class="text-sm font-medium text-txt-primary"
            >Compartir artículo:</span
          >
          <button
            id="share-twitter"
            aria-label="Compartir en Twitter"
            class="w-11 h-11 rounded-lg bg-bg-surface border border-border-subtle flex items-center justify-center text-txt-muted hover:text-txt-primary hover:border-txt-muted transition-colors"
          >
            <Icon name="twitter" size={18} />
          </button>
          <button
            id="share-linkedin"
            aria-label="Compartir en LinkedIn"
            class="w-11 h-11 rounded-lg bg-bg-surface border border-border-subtle flex items-center justify-center text-txt-muted hover:text-txt-primary hover:border-txt-muted transition-colors"
          >
            <Icon name="linkedin" size={18} />
          </button>
          <button
            id="share-copy"
            aria-label="Copiar enlace"
            class="w-11 h-11 rounded-lg bg-bg-surface border border-border-subtle flex items-center justify-center text-txt-muted hover:text-txt-primary hover:border-txt-muted transition-colors"
          >
            <Icon name="link" size={18} />
          </button>
        </div>
      </div>
    </article>
  </section>

  <!-- Comments -->
  <Comments term={post.slug} />

  <!-- Related Posts -->
  <section
    class="border-t border-border-subtle px-4 sm:px-6 md:px-10 lg:px-20 py-10 sm:py-12 md:py-[60px] flex flex-col gap-6 sm:gap-8"
  >
    <div class="flex flex-col gap-2">
      <span class="font-mono text-sm font-medium text-accent"
        >// related_posts</span
      >
      <h2 class="text-xl sm:text-2xl lg:text-3xl font-bold text-txt-primary">También te puede interesar</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      {
        relatedPosts.map((p) => {
          const pWordCount = p.body.split(/\s+/).length;
          const pReadTime = `${Math.max(1, Math.ceil(pWordCount / 200))} min read`;
          return (
            <BlogCard
              slug={p.slug}
              title={p.data.title}
              description={p.data.description}
              tags={p.data.tags}
              date={formatDate(p.data.date)}
              readTime={pReadTime}
              image={p.data.image}
            />
          );
        })
      }
    </div>
  </section>
</BaseLayout>

<script>
  document.getElementById('share-twitter')?.addEventListener('click', () => {
    window.open(
      'https://twitter.com/intent/tweet?url=' +
        encodeURIComponent(window.location.href) +
        '&text=' +
        encodeURIComponent(document.title),
      '_blank',
      'noopener,noreferrer'
    );
  });

  document.getElementById('share-linkedin')?.addEventListener('click', () => {
    window.open(
      'https://www.linkedin.com/sharing/share-offsite/?url=' +
        encodeURIComponent(window.location.href),
      '_blank',
      'noopener,noreferrer'
    );
  });

  document.getElementById('share-copy')?.addEventListener('click', () => {
    const btn = document.getElementById('share-copy');
    navigator.clipboard.writeText(window.location.href).then(() => {
      btn?.classList.add('!text-accent', '!border-accent');
      setTimeout(() => {
        btn?.classList.remove('!text-accent', '!border-accent');
      }, 2000);
    });
  });
</script>

<script>
  const tocLinks = document.querySelectorAll('[data-toc-link]');
  const headings = document.querySelectorAll('article h2');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          tocLinks.forEach((link) => {
            link.classList.remove('border-accent', 'text-accent', 'font-medium');
            link.classList.add('border-transparent', 'text-txt-muted');
          });
          const activeId = entry.target.id;
          const activeLink = document.querySelector(`[data-toc-link="${activeId}"]`);
          if (activeLink) {
            activeLink.classList.remove('border-transparent', 'text-txt-muted');
            activeLink.classList.add('border-accent', 'text-accent', 'font-medium');
          }
        }
      });
    },
    { rootMargin: '0px 0px -70% 0px', threshold: 0 }
  );

  headings.forEach((heading) => observer.observe(heading));
</script>

<style is:global>
  /* Markdown prose styling */
  .prose-custom {
    @apply text-base leading-[1.8];
  }

  .prose-custom h2 {
    @apply text-xl sm:text-2xl font-bold text-txt-primary mt-8 sm:mt-10 mb-4;
  }

  .prose-custom h3 {
    @apply text-lg sm:text-xl font-bold text-txt-primary mt-6 sm:mt-8 mb-3;
  }

  .prose-custom h4 {
    @apply text-lg font-semibold text-txt-primary mt-6 mb-2;
  }

  .prose-custom p {
    @apply text-base text-txt-secondary leading-[1.8] mb-5;
  }

  .prose-custom a {
    @apply text-accent hover:underline;
  }

  /* Preserve explicit text colors on CTA buttons inside prose */
  .prose-custom a.cta-button {
    color: rgb(var(--bg-deep)) !important;
    text-decoration: none !important;
  }
  .prose-custom a.cta-button:hover {
    text-decoration: none !important;
  }

  .prose-custom strong {
    @apply text-txt-primary font-semibold;
  }

  .prose-custom em {
    @apply text-txt-primary italic;
  }

  .prose-custom ul {
    @apply list-disc list-inside text-txt-secondary mb-5 space-y-1.5;
  }

  .prose-custom ol {
    @apply list-decimal list-inside text-txt-secondary mb-5 space-y-1.5;
  }

  .prose-custom li {
    @apply text-base leading-[1.7];
  }

  .prose-custom blockquote {
    @apply border-l-[3px] border-accent pl-5 py-3 my-6 rounded-r-lg;
    background-color: rgb(var(--accent) / 0.05);
  }

  .prose-custom blockquote p {
    @apply text-txt-primary text-sm leading-[1.6] mb-0;
  }

  .prose-custom code {
    @apply font-mono text-[13px] text-accent bg-code-bg rounded px-1.5 py-0.5;
    word-break: break-word;
  }

  .prose-custom pre {
    @apply rounded-lg sm:rounded-xl border border-border-subtle overflow-hidden p-3 sm:p-5 my-4 sm:my-6 overflow-x-auto;
    background-color: rgb(var(--code-bg)) !important;
    -webkit-overflow-scrolling: touch;
  }

  .prose-custom pre code {
    @apply bg-transparent p-0 text-[13px] leading-[1.7];
    color: inherit;
  }

  /* Shiki dual-theme support: switch syntax colors in dark mode */
  html.dark .astro-code,
  html.dark .astro-code span {
    color: var(--shiki-dark) !important;
    font-style: var(--shiki-dark-font-style) !important;
    font-weight: var(--shiki-dark-font-weight) !important;
    text-decoration: var(--shiki-dark-text-decoration) !important;
  }

  .prose-custom hr {
    @apply border-border-subtle my-8;
  }

  .prose-custom table {
    @apply w-full border-collapse my-6 text-sm;
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .prose-custom thead th {
    @apply text-left text-txt-primary font-semibold border-b border-border-subtle py-2.5 px-3;
  }

  .prose-custom tbody td {
    @apply text-txt-secondary border-b border-border-subtle py-2.5 px-3;
  }

  .prose-custom img {
    @apply rounded-lg sm:rounded-xl my-4 sm:my-6 max-w-full h-auto;
  }
</style>
