---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogCard from "../../../components/BlogCard.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const uniqueTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts
      .filter((post) => post.data.tags.includes(tag))
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;

// Format date helper
function formatDate(date: Date): string {
  return date.toLocaleDateString("es-ES", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<BaseLayout
  title={`Artículos sobre ${tag} — Ingeniería sin filtros`}
  description={`Explorá todos los artículos sobre ${tag} en el blog de Ingeniería sin filtros.`}
  navVariant="blog"
  footerVariant="simple"
>
  <section class="flex flex-col items-center gap-6 sm:gap-8 px-4 sm:px-6 md:px-10 lg:px-20 py-10 sm:py-12 md:py-[60px]">
    <span class="font-mono text-sm font-medium text-accent animate-pulse">
      // blog / tags / {tag}
    </span>
    <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-[42px] font-bold text-txt-primary text-center">
      Etiqueta: <span class="text-accent">#{tag}</span>
    </h1>
    <a href="/blog" class="text-txt-muted hover:text-accent transition-colors text-sm">
      &larr; Volver al blog completo
    </a>
  </section>

  <section class="px-4 sm:px-6 md:px-10 lg:px-20 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        posts.map((post) => {
          const wordCount = post.body?.split(/\s+/).length || 0;
          const readTime = `${Math.max(1, Math.ceil(wordCount / 200))} min read`;
          return (
            <BlogCard
              slug={post.id}
              title={post.data.title}
              description={post.data.description}
              tags={post.data.tags}
              date={formatDate(post.data.date)}
              readTime={readTime}
              image={post.data.image}
            />
          );
        })
      }
    </div>
  </section>
</BaseLayout>
