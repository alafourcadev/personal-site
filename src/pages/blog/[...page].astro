---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import BlogCard from "../../components/BlogCard.astro";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const sorted = posts.sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  );
  return paginate(sorted, { pageSize: 9 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

// Generate filter tags from THIS page's posts
const allTags = [...new Set(page.data.flatMap((p) => p.data.tags))];
const filterTags = ["All", ...allTags];

// Format date helper
function formatDate(date: Date): string {
  return date.toLocaleDateString("es-ES", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

// Build page numbers array
const pageNumbers = Array.from({ length: page.lastPage }, (_, i) => i + 1);
---

<BaseLayout
  title="Blog — Ingeniería sin filtros"
  description="Artículos sobre ingeniería de software, arquitectura de sistemas y las decisiones técnicas que nadie te enseña."
  navVariant="blog"
  footerVariant="simple"
>
  <!-- Blog Header -->
  <section class="flex flex-col items-center gap-6 sm:gap-8 px-4 sm:px-6 md:px-10 lg:px-20 py-10 sm:py-12 md:py-[60px]">
    <span class="font-mono text-sm font-medium text-accent animate-pulse"
      >// blog</span
    >
    <h1
      class="text-2xl sm:text-3xl md:text-4xl lg:text-[42px] font-bold text-txt-primary text-center animate-fade-in"
    >
      Artículos
    </h1>
    <p
      class="text-[15px] sm:text-[17px] text-txt-secondary text-center max-w-2xl animate-fade-in"
      style="animation-delay: 100ms"
    >
      Ingeniería de software, arquitectura de sistemas y las decisiones técnicas
      que nadie te enseña.
    </p>

    <!-- Search -->
    <div
      class="search-container flex items-center gap-3 w-full max-w-[560px] h-12 bg-bg-surface border border-border-subtle rounded-xl px-4 transition-all duration-300 focus-within:border-accent/50 focus-within:shadow-[0_0_20px_rgba(52,211,153,0.15)]"
    >
      <Icon
        name="search"
        size={18}
        class="text-txt-muted shrink-0 transition-colors duration-300"
      />
      <input
        id="blog-search"
        type="text"
        placeholder="Buscar artículos..."
        aria-label="Buscar artículos"
        class="bg-transparent text-[15px] text-txt-primary placeholder:text-txt-muted outline-none flex-1"
      />
    </div>

    <!-- Tags -->
    <div class="flex flex-wrap items-center gap-2 sm:gap-2.5 justify-center">
      {
        filterTags.map((tag, i) => (
          <button
            data-tag={tag}
            class:list={[
              "tag-btn text-[13px] font-medium rounded-full px-4 py-2.5 min-h-[44px] transition-all duration-300 cursor-pointer hover:scale-105",
              i === 0
                ? "bg-accent text-bg-deep font-semibold active-tag shadow-[0_0_15px_rgba(52,211,153,0.3)]"
                : "bg-bg-surface text-txt-secondary border border-border-subtle hover:border-accent/50 hover:text-txt-primary",
            ]}
            style={`animation-delay: ${i * 50}ms`}
          >
            {tag}
          </button>
        ))
      }
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="px-4 sm:px-6 md:px-10 lg:px-20 pb-12">
    <div
      id="blog-grid"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
    >
      {
        page.data.map((post, i) => {
          const wordCount = post.body.split(/\s+/).length;
          const readTime = `${Math.max(1, Math.ceil(wordCount / 200))} min read`;
          return (
            <div
              class="blog-card-wrapper"
              style={`animation-delay: ${i * 100}ms`}
            >
              <BlogCard
                slug={post.slug}
                title={post.data.title}
                description={post.data.description}
                tags={post.data.tags}
                date={formatDate(post.data.date)}
                readTime={readTime}
                image={post.data.image}
              />
            </div>
          );
        })
      }
    </div>
    <p id="no-results" class="hidden text-center text-txt-muted py-12">
      No se encontraron artículos.
    </p>
  </section>

  <!-- Pagination -->
  {
    page.lastPage > 1 && (
      <nav
        aria-label="Paginación del blog"
        class="flex items-center justify-center gap-2 px-4 sm:px-6 md:px-10 lg:px-20 pb-20"
      >
        {/* Previous */}
        {page.url.prev ? (
          <a
            href={page.url.prev}
            class="flex items-center gap-1.5 text-[13px] font-medium rounded-full px-4 py-2.5 bg-bg-surface text-txt-secondary border border-border-subtle hover:border-accent/50 hover:text-txt-primary transition-all duration-300 hover:scale-105"
          >
            &larr; Anterior
          </a>
        ) : (
          <span class="flex items-center gap-1.5 text-[13px] font-medium rounded-full px-4 py-2.5 bg-bg-surface text-txt-muted border border-border-subtle opacity-50 cursor-not-allowed select-none">
            &larr; Anterior
          </span>
        )}

        {/* Page numbers */}
        {pageNumbers.map((num) => {
          const isActive = num === page.currentPage;
          const href =
            num === 1 ? "/blog" : `/blog/${num}`;
          return isActive ? (
            <span
              class="text-[13px] font-semibold rounded-full px-4 py-2.5 bg-accent text-bg-deep shadow-[0_0_15px_rgba(52,211,153,0.3)] min-w-[44px] text-center"
              aria-current="page"
            >
              {num}
            </span>
          ) : (
            <a
              href={href}
              class="text-[13px] font-medium rounded-full px-4 py-2.5 bg-bg-surface text-txt-secondary border border-border-subtle hover:border-accent/50 hover:text-txt-primary transition-all duration-300 hover:scale-105 min-w-[44px] text-center"
            >
              {num}
            </a>
          );
        })}

        {/* Next */}
        {page.url.next ? (
          <a
            href={page.url.next}
            class="flex items-center gap-1.5 text-[13px] font-medium rounded-full px-4 py-2.5 bg-bg-surface text-txt-secondary border border-border-subtle hover:border-accent/50 hover:text-txt-primary transition-all duration-300 hover:scale-105"
          >
            Siguiente &rarr;
          </a>
        ) : (
          <span class="flex items-center gap-1.5 text-[13px] font-medium rounded-full px-4 py-2.5 bg-bg-surface text-txt-muted border border-border-subtle opacity-50 cursor-not-allowed select-none">
            Siguiente &rarr;
          </span>
        )}
      </nav>
    )
  }
</BaseLayout>

<script>
  const searchInput = document.getElementById(
    "blog-search",
  ) as HTMLInputElement | null;
  const tagButtons = document.querySelectorAll<HTMLButtonElement>(".tag-btn");
  const cards = document.querySelectorAll<HTMLElement>("[data-blog-card]");
  const noResults = document.getElementById("no-results");

  let activeTag = "All";

  function filterCards() {
    const query = searchInput?.value.toLowerCase() ?? "";
    let visible = 0;

    cards.forEach((card) => {
      const tags = card.dataset.tags ?? "";
      const title = card.dataset.title ?? "";
      const description = card.dataset.description ?? "";

      const matchesTag = activeTag === "All" || tags.includes(activeTag);
      const matchesSearch =
        query === "" || title.includes(query) || description.includes(query);

      const show = matchesTag && matchesSearch;
      card.style.display = show ? "" : "none";
      if (show) visible++;
    });

    if (noResults) noResults.style.display = visible === 0 ? "block" : "none";
  }

  searchInput?.addEventListener("input", filterCards);

  tagButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeTag = btn.dataset.tag ?? "All";

      tagButtons.forEach((b) => {
        if (b.dataset.tag === activeTag) {
          b.className =
            "tag-btn text-[13px] font-semibold rounded-full px-4 py-2.5 min-h-[44px] transition-all duration-300 cursor-pointer hover:scale-105 bg-accent text-bg-deep active-tag shadow-[0_0_15px_rgba(52,211,153,0.3)]";
        } else {
          b.className =
            "tag-btn text-[13px] font-medium rounded-full px-4 py-2.5 min-h-[44px] transition-all duration-300 cursor-pointer hover:scale-105 bg-bg-surface text-txt-secondary border border-border-subtle hover:border-accent/50 hover:text-txt-primary";
        }
      });

      filterCards();
    });
  });
</script>

<style>
  /* Fade in animation */
  .animate-fade-in {
    opacity: 0;
    animation: fadeIn 0.6s ease-out forwards;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }

  /* Blog card staggered animation */
  .blog-card-wrapper {
    opacity: 0;
    animation: cardSlideIn 0.5s ease-out forwards;
  }

  @keyframes cardSlideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Tag buttons animation */
  .tag-btn {
    opacity: 0;
    animation: tagFadeIn 0.3s ease-out forwards;
  }

  @keyframes tagFadeIn {
    to {
      opacity: 1;
    }
  }
</style>
