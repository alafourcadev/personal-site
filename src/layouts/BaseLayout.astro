---
// Font imports - only weights used in the site
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/outfit/700.css';
import '@fontsource/outfit/800.css';

import Navbar from '../components/Navbar.astro';
import TypewriterLogo from '../components/TypewriterLogo.astro';
import FooterFull from '../components/FooterFull.astro';
import FooterSimple from '../components/FooterSimple.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  navVariant?: 'home' | 'blog';
  footerVariant?: 'full' | 'simple';
}

const {
  title,
  description = 'Ingeniería sin filtros — Alejandro Lafourcade',
  image,
  type = 'website',
  navVariant = 'home',
  footerVariant = 'full',
} = Astro.props;

const ogImage = image || 'https://alafourca.dev/og-image.png';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Alejandro Lafourcade" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" type="application/rss+xml" title="alafourca.dev" href="/rss.xml" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="alafourca.dev" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@alafourcadev" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Alejandro Lafourcade",
      "jobTitle": "Tech Lead & Software Engineer",
      "url": "https://alafourca.dev",
      "sameAs": [
        "https://x.com/alafourcadev",
        "https://www.linkedin.com/in/alafourcadedespaigne/",
        "https://github.com/alafourcadev"
      ]
    })} />
    <meta name="theme-color" content="#0a0f1a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)" />
    <link rel="alternate" hreflang="es" href={Astro.url.href} />
    <slot name="head" />
    <script is:inline>
      // Load theme before page renders to prevent flash
      (function () {
        const saved = localStorage.getItem('theme');
        if (saved === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "f2044e16dcba4f17ae6792df334e9d1b"}'></script>
    <script defer src="https://cloud.umami.is/script.js" data-website-id="7a77490e-3189-4843-84c2-b5971d0bbc81"></script>
  </head>
  <body
    class="bg-bg-deep text-txt-primary font-sans antialiased overflow-x-hidden"
  >
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-accent focus:text-bg-deep focus:rounded-lg focus:font-bold">
      Saltar al contenido
    </a>
    <TypewriterLogo />
    <Navbar variant={navVariant} />
    <div class="max-w-[1440px] mx-auto">
      <main id="main-content" class="pt-20">
        <slot />
      </main>
      {footerVariant === 'full' ? <FooterFull /> : <FooterSimple />}
    </div>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  html {
    scroll-behavior: smooth;
  }

  /* Light mode (default when no dark class) */
  :root {
    --bg-deep: 248 250 252;
    --bg-surface: 255 255 255;
    --bg-surface-hover: 241 245 249;
    --border-subtle: 226 232 240;
    --code-bg: 241 245 249;
    --txt-primary: 30 41 59;
    --txt-secondary: 71 85 105;
    --txt-muted: 148 163 184;
    --accent: 16 185 129;
    --tag-bg: 236 253 245;
    --tag-text: 4 120 87;
    --nav-bg: rgba(255, 255, 255, 0.8);
    --scrollbar-track: #f1f5f9;
    --scrollbar-thumb: #cbd5e1;
    --scrollbar-thumb-hover: #94a3b8;
  }

  /* Dark mode (when dark class is present) */
  html.dark {
    --bg-deep: 10 15 26;
    --bg-surface: 19 27 46;
    --bg-surface-hover: 26 37 64;
    --border-subtle: 30 45 74;
    --code-bg: 13 17 23;
    --txt-primary: 226 232 240;
    --txt-secondary: 148 163 184;
    --txt-muted: 124 141 181;
    --accent: 52 211 153;
    --tag-bg: 6 78 59;
    --tag-text: 110 231 183;
    --nav-bg: rgba(15, 23, 42, 0.8);
    --scrollbar-track: #0f172a;
    --scrollbar-thumb: #334155;
    --scrollbar-thumb-hover: #475569;
  }

  /* Apply CSS variables */
  body {
    background-color: rgb(var(--bg-deep));
    color: rgb(var(--txt-primary));
  }

  ::selection {
    background: rgba(16, 185, 129, 0.3);
    color: inherit;
  }

  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: var(--scrollbar-track);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--scrollbar-thumb);
    border-radius: 9999px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--scrollbar-thumb-hover);
  }

  a:focus-visible, button:focus-visible {
    outline: 2px solid rgb(var(--accent));
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* Theme-aware card hover shadow */
  .card-hover-shadow:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }
  html.dark .card-hover-shadow:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
